    <sectiondef kind="func">
      <memberdef kind="function" id="group__stream__extractor_1ga0abe11e8e9922d5ac662fc59ee34231d" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>VLC_API <ref refid="structstream__t" kindref="compound">stream_t</ref> *</type>
        <definition>VLC_API stream_t * vlc_stream_NewMRL</definition>
        <argsstring>(vlc_object_t *obj, const char *mrl) VLC_USED</argsstring>
        <name>vlc_stream_NewMRL</name>
        <param>
          <type><ref refid="structvlc__object__t" kindref="compound">vlc_object_t</ref> *</type>
          <declname>obj</declname>
        </param>
        <param>
          <type>const char *</type>
          <declname>mrl</declname>
        </param>
        <briefdescription>
        </briefdescription>
        <detaileddescription>
<para>Create a stream for the data referred to by a mrl</para>
<para>This function will create a <ref refid="group__stream" kindref="compound">Stream</ref> that reads from the specified mrl, potentially making use of <ref refid="group__stream__extractor" kindref="compound">Stream Extractor</ref>s to access named entities within the data read from the original source.</para>
<para><itemizedlist>
<listitem><para>See the mrl specification for further information.</para>
</listitem><listitem><para>The returned resource shall be deleted through <ref refid="group__stream_1ga312a17d8be94eb50948391703b071773" kindref="member">vlc_stream_Delete</ref>.</para>
</listitem></itemizedlist>
</para>
<para><simplesect kind="warning"><para>This function is only to be used when mrl functionality is explicitly needed. vlc_stream_NewURL shall be used where applicable.</para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>obj</parametername>
</parameternamelist>
<parameterdescription>
<para>the owner of the requested stream </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>mrl</parametername>
</parameternamelist>
<parameterdescription>
<para>the mrl for which the <ref refid="structstream__t" kindref="compound">stream_t</ref> should be created </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><computeroutput>NULL</computeroutput> on error, a pointer to <ref refid="structstream__t" kindref="compound">stream_t</ref> on success. </para>
</simplesect>
</para>
        </detaileddescription>
