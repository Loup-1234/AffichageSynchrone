        <type>VLC_API int</type>
        <definition>VLC_API int vlc_open</definition>
        <argsstring>(const char *filename, int flags,...) VLC_USED</argsstring>
        <name>vlc_open</name>
        <param>
          <type>const char *</type>
          <declname>filename</declname>
        </param>
        <param>
          <type>int</type>
          <declname>flags</declname>
        </param>
        <param>
          <type>...</type>
        </param>
        <briefdescription>
        </briefdescription>
        <detaileddescription>
<para>Opens a system file handle.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>filename</parametername>
</parameternamelist>
<parameterdescription>
<para>file path to open (with UTF-8 encoding) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>flags</parametername>
</parameternamelist>
<parameterdescription>
<para>open() flags, see the C library open() documentation </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>a file handle on success, -1 on error (see errno). </para>
</simplesect>
<simplesect kind="note"><para>Contrary to standard open(), this function returns a file handle with the close-on-exec flag preset. </para>
</simplesect>
</para>
        </detaileddescription>
