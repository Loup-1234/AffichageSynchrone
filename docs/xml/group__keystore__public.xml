        <detaileddescription>
<para>Store a secret associated with a set of key/values</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>ppsz_values</parametername>
</parameternamelist>
<parameterdescription>
<para>set of key/values, see <ref refid="group__keystore__public_1ga7fe53cc92bf0fc6075518d916483267d" kindref="member">vlc_keystore_key</ref>. ppsz_values[KEY_PROTOCOL] and ppsz_values[KEY_SERVER] must be valid strings </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>p_secret</parametername>
</parameternamelist>
<parameterdescription>
<para>binary secret or string password </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>i_secret_len</parametername>
</parameternamelist>
<parameterdescription>
<para>length of p_secret. If it&apos;s less than 0, then p_secret is assumed to be a &apos;\0&apos; terminated string </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>psz_label</parametername>
</parameternamelist>
<parameterdescription>
<para>user friendly label</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>VLC_SUCCESS on success, or VLC_EGENERIC on error </para>
</simplesect>
</para>
