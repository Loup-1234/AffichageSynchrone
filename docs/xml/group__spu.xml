                <briefdescription>
                </briefdescription>
                <detaileddescription>
                    <para>This function will return an unique subpicture containing the OSD and subtitles visibles at
                        the requested date.
                    </para>
                    <para>
                        <parameterlist kind="param">
                            <parameteritem>
                                <parameternamelist>
                                    <parametername>p_chroma_list</parametername>
                                </parameternamelist>
                                <parameterdescription>
                                    <para>is a list of supported chroma for the output (can be NULL)</para>
                                </parameterdescription>
                            </parameteritem>
                            <parameteritem>
                                <parameternamelist>
                                    <parametername>p_fmt_dst</parametername>
                                </parameternamelist>
                                <parameterdescription>
                                    <para>is the format of the picture on which the return subpicture will be
                                        rendered.
                                    </para>
                                </parameterdescription>
                            </parameteritem>
                            <parameteritem>
                                <parameternamelist>
                                    <parametername>p_fmt_src</parametername>
                                </parameternamelist>
                                <parameterdescription>
                                    <para>is the format of the original(source) video.</para>
                                </parameterdescription>
                            </parameteritem>
                        </parameterlist>
                        The returned value if non NULL must be released by <ref
                            refid="group__subpicture_1ga86b24b8b7a37505a97ce99e34b8fa83e" kindref="member">
                        subpicture_Delete()</ref>.
                    </para>
                </detaileddescription>
