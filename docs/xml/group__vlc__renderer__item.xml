        <detaileddescription>
<para>Create a new renderer item</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>psz_type</parametername>
</parameternamelist>
<parameterdescription>
<para>type of the item </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>psz_name</parametername>
</parameternamelist>
<parameterdescription>
<para>name of the item </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>psz_uri</parametername>
</parameternamelist>
<parameterdescription>
<para>uri of the renderer item, must contains a valid protocol and a valid host </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>psz_extra_sout</parametername>
</parameternamelist>
<parameterdescription>
<para>extra sout options </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>psz_demux_filter</parametername>
</parameternamelist>
<parameterdescription>
<para>demux filter to use with the renderer </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>psz_icon_uri</parametername>
</parameternamelist>
<parameterdescription>
<para>icon uri of the renderer item </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>i_flags</parametername>
</parameternamelist>
<parameterdescription>
<para>flags for the item </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>a renderer item or NULL in case of error </para>
</simplesect>
</para>
