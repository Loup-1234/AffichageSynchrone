      <memberdef kind="function" id="group__fifo_1gae03d77fb47001cfb35223b0b3cdc28df" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>VLC_API void</type>
        <definition>VLC_API void vlc_fifo_Lock</definition>
        <argsstring>(vlc_fifo_t *)</argsstring>
        <name>vlc_fifo_Lock</name>
        <param>
          <type>vlc_fifo_t *</type>
        </param>
        <briefdescription>
        </briefdescription>
        <detaileddescription>
<para>Locks a block FIFO.</para>
<para>No more than one thread can lock the FIFO at any given time, and no other thread can modify the FIFO while it is locked. <ref refid="group__fifo_1ga986af097c87339596885781781d4906a" kindref="member">vlc_fifo_Unlock()</ref> releases the lock.</para>
<para><simplesect kind="note"><para>If the FIFO is already locked by another thread, this function waits. This function is not a cancellation point.</para>
</simplesect>
<simplesect kind="warning"><para>Recursively locking a single FIFO is undefined. Locking more than one FIFO at a time may lead to lock inversion; mind the locking order. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="C:/Users/ahumeaub/Desktop/CLionProject/AffichageSynchrone/include/LibVLC/include/vlc/plugins/vlc_block.h" line="494" column="14" declfile="C:/Users/ahumeaub/Desktop/CLionProject/AffichageSynchrone/include/LibVLC/include/vlc/plugins/vlc_block.h" declline="494" declcolumn="14"/>
      </memberdef>
