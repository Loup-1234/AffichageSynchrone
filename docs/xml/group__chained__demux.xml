        <argsstring>(vlc_object_t *parent, const char *name, es_out_t *out)</argsstring>
        <name>vlc_demux_chained_New</name>
        <param>
          <type><ref refid="structvlc__object__t" kindref="compound">vlc_object_t</ref> *</type>
          <declname>parent</declname>
