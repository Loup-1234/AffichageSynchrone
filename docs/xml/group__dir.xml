                <type>VLC_API const char *</type>
                <definition>VLC_API const char * vlc_readdir</definition>
                <argsstring>(DIR *dir) VLC_USED</argsstring>
                <name>vlc_readdir</name>
                <param>
                    <type>DIR *</type>
                    <declname>dir</declname>
                </param>
                <briefdescription>
                </briefdescription>
                <detaileddescription>
                    <para>Reads the next file name from an open directory.</para>
                    <para>
                        <parameterlist kind="param">
                            <parameteritem>
                                <parameternamelist>
                                    <parametername>dir</parametername>
                                </parameternamelist>
                                <parameterdescription>
                                    <para>directory handle as returned by <ref
                                            refid="group__dir_1ga41c608bd6a568eca71a508cf544cdb3f" kindref="member">
                                        vlc_opendir()
                                    </ref> (must not be used by another thread concurrently)
                                    </para>
                                </parameterdescription>
                            </parameteritem>
                        </parameterlist>
                        <simplesect kind="return">
                            <para>a UTF-8 string of the directory entry. The string is valid until the next call to <ref
                                    refid="group__dir_1ga63802dea65b9a23e11bbf08ad6ffd863" kindref="member">
                                vlc_readdir()
                            </ref> or closedir() on the handle. If there are no more entries in the directory, NULL is
                                returned. If an error occurs, errno is set and NULL is returned.
                            </para>
                        </simplesect>
                    </para>
                </detaileddescription>
