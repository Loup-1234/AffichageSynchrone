                <type>VLC_API DIR *</type>
                <definition>VLC_API DIR * vlc_opendir</definition>
                <argsstring>(const char *dirname) VLC_USED</argsstring>
                <name>vlc_opendir</name>
                <param>
                    <type>const char *</type>
                    <declname>dirname</declname>
                </param>
                <briefdescription>
                </briefdescription>
                <detaileddescription>
                    <para>Opens a DIR pointer.</para>
                    <para>
                        <parameterlist kind="param">
                            <parameteritem>
                                <parameternamelist>
                                    <parametername>dirname</parametername>
                                </parameternamelist>
                                <parameterdescription>
                                    <para>UTF-8 representation of the directory name</para>
                                </parameterdescription>
                            </parameteritem>
                        </parameterlist>
                        <simplesect kind="return">
                            <para>a pointer to the DIR struct, or NULL in case of error. Release with standard
                                closedir().
                            </para>
                        </simplesect>
                    </para>
                </detaileddescription>
