        <type>VLC_API int</type>
        <definition>VLC_API int vlc_stream_fifo_Queue</definition>
        <argsstring>(stream_t *s, block_t *block)</argsstring>
        <name>vlc_stream_fifo_Queue</name>
        <param>
          <type><ref refid="structstream__t" kindref="compound">stream_t</ref> *</type>
          <declname>s</declname>
        </param>
        <param>
          <type><ref refid="structblock__t" kindref="compound">block_t</ref> *</type>
          <declname>block</declname>
        </param>
        <briefdescription>
        </briefdescription>
        <detaileddescription>
<para>Writes a block to a FIFO stream.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>s</parametername>
</parameternamelist>
<parameterdescription>
<para>FIFO stream created by <ref refid="group__stream__fifo_1ga5df89e172b2ac079a5ff53478fc3a48a" kindref="member">vlc_stream_fifo_New()</ref> </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>block</parametername>
</parameternamelist>
<parameterdescription>
<para>data block to write to the stream </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>0 on success. -1 if the reader end has already been closed (errno is then set to EPIPE, and the block is deleted).</para>
</simplesect>
<xrefsect id="bug_1_bug000006"><xreftitle>Bogue</xreftitle><xrefdescription><para>No congestion control is performed. If the reader end is not keeping up with the writer end, buffers will accumulate in memory. </para>
</xrefdescription></xrefsect></para>
        </detaileddescription>
