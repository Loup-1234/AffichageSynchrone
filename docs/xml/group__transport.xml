        <type>VLC_API ssize_t</type>
        <definition>VLC_API ssize_t vlc_tls_Read</definition>
        <argsstring>(vlc_tls_t *, void *buf, size_t len, bool waitall)</argsstring>
        <name>vlc_tls_Read</name>
        <param>
          <type><ref refid="group__transport_1gad9e89acad0e40f270f6e07cacba4be19" kindref="member">vlc_tls_t</ref> *</type>
