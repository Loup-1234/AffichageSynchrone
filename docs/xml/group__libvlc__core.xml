        <definition>LIBVLC_API void libvlc_set_exit_handler</definition>
        <argsstring>(libvlc_instance_t *p_instance, void(*cb)(void *), void *opaque)</argsstring>
        <name>libvlc_set_exit_handler</name>
        <param>
          <type><ref refid="group__libvlc__core_1ga316d739a80da4678206c79f4d6c2e284" kindref="member">libvlc_instance_t</ref> *</type>
